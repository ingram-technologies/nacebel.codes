{
	"name": "nacebel-codes",
	"version": "0.1.0",
	"private": true,
	"scripts": {
		"build": "next build",
		"dev": "next dev",
		"lint": "nk lint",
		"start": "next start",
		"format": "nk format",
		"check": "nk check",
		"type-check": "nk type-check",
		"prepare": "git config core.hooksPath .githooks || true"
	},
	"dependencies": {
		"@base-ui/react": "^1.6.0",
		"@ingram-tech/nk-i18n": "^0.1.3",
		"@tailwindcss/postcss": "^4.3.2",
		"class-variance-authority": "^0.7.1",
		"clsx": "^2.1.1",
		"lucide-react": "^1.24.0",
		"nace-codes": "^1.0.3",
		"next": "16.2.10",
		"next-themes": "^0.4.6",
		"postcss": "^8.5.16",
		"react": "^19",
		"react-dom": "^19",
		"shadcn": "^4.13.0",
		"sonner": "^2.0.7",
		"tailwind-merge": "^3.6.0",
		"tailwindcss-animate": "^1.0.7"
	},
	"devDependencies": {
		"@ingram-tech/nk-dev": "^0.4.1",
		"@types/node": "^26",
		"@types/react": "^19",
		"@types/react-dom": "^19",
		"tailwindcss": "^4.3.2"
	},
	"postcss": {
		"plugins": {
			"@tailwindcss/postcss": {}
		}
	},
	"prettier": {
		"trailingComma": "all",
		"printWidth": 88,
		"useTabs": true,
		"tabWidth": 4,
		"experimentalOperatorPosition": "start",
		"plugins": [
			"prettier-plugin-organize-imports"
		],
		"overrides": [
			{
				"files": [
					"*.yaml",
					"*.yml"
				],
				"options": {
					"useTabs": false,
					"tabWidth": 2
				}
			}
		]
	}
}
